generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  username    String?  @unique
  bio         String?
  avatarUrl   String?

  accounts     Account[]
  sessions     Session[]
  credits      UserCredits?
  transactions CreditTransaction[]
  dailyUsages  DailyUsage[]
  projects     Project[]
  likes        Like[]
  savedWorks   SavedWork[]
  following    Follow[]  @relation("Follower")
  followers    Follow[]  @relation("Following")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserCredits {
  id             String   @id @default(cuid())
  userId         String   @unique
  creditsBalance Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// type: purchase | spend | refund | bonus
model CreditTransaction {
  id          String   @id @default(cuid())
  userId      String
  projectId   String?
  type        String
  amount      Int
  description String
  createdAt   DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id])
}

model DailyUsage {
  id                  String   @id @default(cuid())
  userId              String?
  anonymousId         String?
  date                String
  freeGenerationsUsed Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@unique([anonymousId, date])
}

// generationMode: free | paid
// status: pending | processing | completed | failed
model Project {
  id             String   @id @default(cuid())
  userId         String
  status         String   @default("pending")
  inputImageUrl  String
  style          String
  generationMode String   @default("free")
  creditsUsed    Int      @default(0)
  outputSize     String   @default("768x768")
  hasWatermark   Boolean  @default(true)
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  variants     ProjectVariant[]
  transactions CreditTransaction[]
}

model ProjectVariant {
  id           String   @id @default(cuid())
  projectId    String
  imageUrl     String
  thumbnailUrl String?
  createdAt    DateTime @default(now())

  isPublic    Boolean  @default(false)
  title       String?
  likeCount   Int      @default(0)
  viewCount   Int      @default(0)

  project Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  likes   Like[]
  savedBy SavedWork[]
}

model ProcessedWebhookEvent {
  id          String   @id
  processedAt DateTime @default(now())
}

model Like {
  id        String         @id @default(cuid())
  userId    String
  variantId String
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant   ProjectVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  @@unique([userId, variantId])
}

model SavedWork {
  id        String         @id @default(cuid())
  userId    String
  variantId String
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant   ProjectVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  @@unique([userId, variantId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  @@unique([followerId, followingId])
}
