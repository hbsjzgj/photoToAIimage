# ============================================================
# データベース
# ローカル開発: SQLite → DATABASE_URL="file:./prisma/dev.db"
# 本番 (Vercel): PostgreSQL (Supabase 推奨)
# ============================================================
DATABASE_URL="file:./prisma/dev.db"

# ============================================================
# NextAuth
# ============================================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-random-secret-here-run-openssl-rand-base64-32"

# ============================================================
# Stripe (https://dashboard.stripe.com)
# ============================================================
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs (ダッシュボード → 商品 → 価格ID をコピー)
STRIPE_PRICE_STARTER="price_..."   # 10 credits ¥500
STRIPE_PRICE_CREATOR="price_..."   # 30 credits ¥1,200
STRIPE_PRICE_PRO="price_..."       # 100 credits ¥3,000

# ============================================================
# Replicate (https://replicate.com/account/api-tokens)
# ============================================================
REPLICATE_API_TOKEN="r8_..."

# ============================================================
# Cloudinary (https://cloudinary.com/console)
# ============================================================
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ============================================================
# AI プロバイダー設定
# ============================================================
# "gemini" | "fal" | "huggingface" | "mock"
# 未設定の場合: GEMINI_API_KEY あり → gemini → fal → mock
#               FAL_KEY あり → fal → mock
#               HUGGINGFACE_API_TOKEN あり → huggingface → mock
#               なし → mock
AI_PROVIDER=""

# Google Gemini (https://aistudio.google.com/app/apikey) ← 推奨: Gemini 2.5 Flash Image
# 設定すると gemini-2.5-flash-preview-05-20 が使われる (image-to-image)
GEMINI_API_KEY=""

# fal.ai (https://fal.ai/dashboard/keys) ← Gemini fallback: FLUX img2img
FAL_KEY=""

# HuggingFace Inference API (https://huggingface.co/settings/tokens)
# FAL_KEY がない場合の代替: instruct-pix2pix img2img
HUGGINGFACE_API_TOKEN=""

# ============================================================
# PostHog アナリティクス (https://posthog.com)
# 本番環境のみ有効（NODE_ENV=production かつキーが設定されている場合）
# ============================================================
NEXT_PUBLIC_POSTHOG_KEY="phc_..."
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# ============================================================
# アプリ設定
# ============================================================
# "true" にすると外部 API を呼ばずモック画像を返す (開発用)
NEXT_PUBLIC_DEMO_MODE="false"
