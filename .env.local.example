# ============================================================
# データベース (SQLite ローカル用)
# ============================================================
DATABASE_URL="file:./prisma/dev.db"

# ============================================================
# NextAuth
# ============================================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-random-secret-here-run-openssl-rand-base64-32"

# ============================================================
# Stripe (https://dashboard.stripe.com)
# ============================================================
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs (ダッシュボード → 商品 → 価格ID をコピー)
STRIPE_PRICE_STARTER="price_..."   # 10 credits ¥500
STRIPE_PRICE_CREATOR="price_..."   # 30 credits ¥1,200
STRIPE_PRICE_PRO="price_..."       # 100 credits ¥3,000

# ============================================================
# Replicate (https://replicate.com/account/api-tokens)
# ============================================================
REPLICATE_API_TOKEN="r8_..."

# ============================================================
# Cloudinary (https://cloudinary.com/console)
# ============================================================
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ============================================================
# AI プロバイダー設定
# ============================================================
# "huggingface" | "mock"
# 未設定の場合は huggingface → mock の順で自動フォールバック
AI_PROVIDER=""

# HuggingFace Inference API (https://huggingface.co/settings/tokens)
# 設定すると instruct-pix2pix で実際の img2img 画像生成が行われる
HUGGINGFACE_API_TOKEN=""

# ============================================================
# アプリ設定
# ============================================================
# "true" にすると外部 API を呼ばずモック画像を返す (開発用)
NEXT_PUBLIC_DEMO_MODE="false"
