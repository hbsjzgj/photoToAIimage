# ============================================================
# データベース
# ローカル開発: SQLite → DATABASE_URL="file:./prisma/dev.db"
# 本番 (Vercel): PostgreSQL (Supabase 推奨)
# ============================================================
DATABASE_URL="file:./prisma/dev.db"

# ============================================================
# NextAuth
# ============================================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-random-secret-here-run-openssl-rand-base64-32"

# ============================================================
# Stripe (https://dashboard.stripe.com)
# ============================================================
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs (ダッシュボード → 商品 → 価格ID をコピー)
STRIPE_PRICE_STARTER="price_..."   # 10 credits ¥500
STRIPE_PRICE_CREATOR="price_..."   # 30 credits ¥1,200
STRIPE_PRICE_PRO="price_..."       # 100 credits ¥3,000

# ============================================================
# Replicate (https://replicate.com/account/api-tokens)
# ============================================================
REPLICATE_API_TOKEN="r8_..."

# ============================================================
# Cloudinary (https://cloudinary.com/console)
# ============================================================
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ============================================================
# AI プロバイダー設定
# ============================================================
# "fal" | "huggingface" | "mock"
# 未設定の場合: FAL_KEY あり → fal → mock / HUGGINGFACE_API_TOKEN あり → huggingface → mock / なし → mock
AI_PROVIDER=""

# fal.ai (https://fal.ai/dashboard/keys) ← 推奨: FLUX img2img で高品質アバター生成
# 設定すると fal-ai/flux/dev/image-to-image が使われる
FAL_KEY=""

# HuggingFace Inference API (https://huggingface.co/settings/tokens)
# FAL_KEY がない場合の代替: instruct-pix2pix img2img
HUGGINGFACE_API_TOKEN=""

# ============================================================
# アプリ設定
# ============================================================
# "true" にすると外部 API を呼ばずモック画像を返す (開発用)
NEXT_PUBLIC_DEMO_MODE="false"
